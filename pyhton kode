def knights_tour(n, start_row, start_col):
    # 8 kemungkinan gerakan kuda
    moves_x = [2, 1, -1, -2, -2, -1, 1, 2]
    moves_y = [1, 2, 2, 1, -1, -2, -2, -1]

    board = [[-1] * n for _ in range(n)]
    board[start_row][start_col] = 0  # Langkah pertama

    def is_valid(x, y):
        return 0 <= x < n and 0 <= y < n and board[x][y] == -1

    # Warnsdorff's heuristic: pilih kotak dengan paling sedikit gerakan lanjutan
    def get_degree(x, y):
        count = 0
        for i in range(8):
            nx, ny = x + moves_x[i], y + moves_y[i]
            if is_valid(nx, ny):
                count += 1
        return count

    def backtrack(x, y, move_count):
        if move_count == n * n:
            return True

        # Urutkan gerakan berdasarkan Warnsdorff's heuristic
        neighbors = []
        for i in range(8):
            nx, ny = x + moves_x[i], y + moves_y[i]
            if is_valid(nx, ny):
                neighbors.append((get_degree(nx, ny), nx, ny))
        neighbors.sort()

        for _, nx, ny in neighbors:
            board[nx][ny] = move_count
            if backtrack(nx, ny, move_count + 1):
                return True
            board[nx][ny] = -1  # Backtrack

        return False

    if backtrack(start_row, start_col, 1):
        return board
    else:
        return None

def print_knight_board(board, n):
    print("\nPapan Tur Kuda (urutan langkah):")
    for row in board:
        print(' '.join(f'{cell:3}' for cell in row))
    print()

    print("Daftar langkah (baris, kolom):")
    steps = [(0, 0)] * (n * n)
    for r in range(n):
        for c in range(n):
            steps[board[r][c]] = (r, c)
    for i, (r, c) in enumerate(steps):
        print(f"Langkah {i+1:3}: baris={r+1}, kolom={c+1}")

