def knapsack_recursive(weights, target, index=0, current=[], current_weight=0):
    """
    Rekursif untuk mencari semua kombinasi yang memenuhi target berat.
    """
    if current_weight == target:
        return [current[:]]  # Solusi ditemukan

    if current_weight > target or index == len(weights):
        return []  # Tidak valid

    solutions = []

    # Pilihan 1: Ambil barang ke-index
    current.append(weights[index])
    solutions += knapsack_recursive(
        weights, target, index + 1,
        current, current_weight + weights[index]
    )
    current.pop()

    # Pilihan 2: Lewati barang ke-index
    solutions += knapsack_recursive(
        weights, target, index + 1,
        current, current_weight
    )

    return solutions

def knapsack_decision(weights, target):
    """Versi keputusan: hanya cari SATU solusi (lebih cepat)."""
    def helper(index, remaining, chosen):
        if remaining == 0:
            return chosen[:]
        if remaining < 0 or index == len(weights):
            return None

        # Ambil barang ke-index
        chosen.append(weights[index])
        result = helper(index + 1, remaining - weights[index], chosen)
        if result is not None:
            return result
        chosen.pop()

        # Lewati barang ke-index
        return helper(index + 1, remaining, chosen)

    return helper(0, target, [])

# Input dari pengguna
